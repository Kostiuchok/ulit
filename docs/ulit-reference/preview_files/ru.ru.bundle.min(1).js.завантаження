r v=[{id:"oksana-sizova",name:"Оксана Сизова",specialization:"художественная литература, young adult, фантастика/фэнтези.",covers:["/rc/img/editors/1/book 01-1.png","/rc/img/editors/1/book 01-2.png","/rc/img/editors/1/book 01-3.png","/rc/img/editors/1/book 01-4.png","/rc/img/editors/1/book 01-5.png"],userpic:"/rc/img/editors/1/portret10.png",quote:"Дорогие авторы! Редактор — это в первую очередь ваш друг. Используя все свои знания, навыки и опыт, он поможет довести вашу книгу до совершенства, вместе подобрать нужные слова, прописать героев так, чтобы и все остальные читатели их полюбили, сопереживали им и с нетерпением ждали очередного сюжетного витка. Мы с вами идем рука об руку и работаем вместе над одной благородной целью — выпустить вашу книгу и показать ее миру.",caption:"издательский отдел Самарского государственного университета, издательский отдел СГАУ им. ак. С. П. Королева, издательство «Perfomance», издательский сервис Rideró."},{id:"olga-rybina",name:"Ольга Рыбина",specialization:"нон-фикшн, художественная литература, в том числе для детей и подростков.",covers:["/rc/img/editors/2/book 02-1.png","/rc/img/editors/2/book 02-2.png","/rc/img/editors/2/book 02-3.png","/rc/img/editors/2/book 02-4.png","/rc/img/editors/2/book 02-5.png"],userpic:"/rc/img/editors/2/portret1.png",quote:"Мы ваши первые читатели. Вдумчивые, аккуратные, не меньше автора заинтересованные в успехе будущей книги. Мы не правим текст автоматически, а внимательно и скрупулезно его изучаем. Вместе с героями ваших книг мы смеемся, плачем, попадаем в переделки, печалимся и переживаем. И всякий раз радуемся, когда ваши книги находят путь к сердцам ваших читателей. Пишите!",caption:"инновационная инфраструктура Уральского федерального университета, издательство «Баско» (Екатеринбург), издательский сервис Rideró."},{id:"marina-tyulkina",name:"Марина Тюлькина",specialization:"художественная, научная литература, научно-методические издания.",covers:["/rc/img/editors/3/book 03-1.png","/rc/img/editors/3/book 03-2.png","/rc/img/editors/3/book 03-3.png","/rc/img/editors/3/book 03-4.png","/rc/img/editors/3/book 03-5.png"],userpic:"/rc/img/editors/3/portret7.png",quote:"Мне как профессиональному редактору приятно отметить, что с каждым годом все больше людей занимаются литературным творчеством. Дорогие авторы, не пишите в стол, выходите на свет! И желаю всем удачи в создании своих шедевров!",caption:"издательства «У-Фактория», «Токмас-Пресс», издательский сервис Rideró."},{id:"elena-milienko",name:"Елена Милиенко",specialization:"художественная литература, публицистика, научная фантастика.",covers:["/rc/img/editors/4/book 04-1.png","/rc/img/editors/4/book 04-2.png","/rc/img/editors/4/book 04-3.png","/rc/img/editors/4/book 04-4.png","/rc/img/editors/4/book 04-5.png"],userpic:"/rc/img/editors/4/portret14.png",quote:"Редактор и автор — это одна команда, цель которой создать классную книгу. Не сдерживайте порывов вдохновения. Пишите о том, что вас волнует. Пишите, как умеете, а мы поможем вам сделать текст логически стройным и привлекательным для будущего читателя.",caption:"журналист и редактор популярных газет и журналов («Новые Известия», «Русский репортер», «ITALIA – Made in Italy, LIVING Italy, «Театрал», и др.). Редактор-составитель издательства «Мастер» и издательства «Эксмо». Специализируется на художественной литературе, публицистике, научной фантастике, литературе для детей, адаптации иностранных текстов (английский и итальянский язык)."},{id:"elena-chijikova",name:"Елена Чижикова",specialization:"художественная литература, психология, саморазвитие, бизнес и финансы.",covers:["/rc/img/editors/5/book 05-1.png","/rc/img/editors/5/book 05-2.png","/rc/img/editors/5/book 05-3.png","/rc/img/editors/5/book 05-4.png"],userpic:"/rc/img/editors/5/portret-5.png",quote:"Каждая новая рукопись открывает для меня новый мир. Мир автора, его героев или идей, его жизненного опыта и вдохновенного творчества. Очень ценно доверие писателя и возможность внести свою небольшую лепту в этот творческий поток, сделать его еще более чистым, сильным и гармоничным.",caption:"издательский центр «Бизнес Букс», издательство «Русский остров», Брянская медицинская газета, портал Finexam, издательский сервис Rideró."},{id:"eugeniya-belyanina",name:"Евгения Белянина",specialization:"художественная литература, публицистика.",covers:["/rc/img/editors/6/book 06-1.png","/rc/img/editors/6/book 06-2.png","/rc/img/editors/6/book 06-3.png","/rc/img/editors/6/book 06-4.png","/rc/img/editors/6/book 06-5.png"],userpic:"/rc/img/editors/6/portret-6.png",caption:"ежемесячный журнал «Театральный сезон» (Екатеринбург), Издательский Дом «Мария» (Екатеринбург), Медиагруппа «Городские вести» (Свердловская область), издательский сервис Rideró."},{id:"nikolay-korolev",name:"Николай Королев",specialization:"публицистика, научно-популярная, художественная литература.",covers:["/rc/img/editors/7/book 07-1.png","/rc/img/editors/7/book 07-2.png","/rc/img/editors/7/book 07-3.png","/rc/img/editors/7/book 07-4.png","/rc/img/editors/7/book 07-5.png"],userpic:"/rc/img/editors/7/portret-4.png",caption:"журналист, ответственный секретарь ежедневной газеты, главный редактор газеты. Образование историческое, техническое."},{id:"natalya-astanina",name:"Наталья Астанина",specialization:"гуманитарная, медицинская, художественная литература, публицистика.",covers:["/rc/img/editors/8/book 08-1.png","/rc/img/editors/8/book 08-2.png","/rc/img/editors/8/book 08-3.png","/rc/img/editors/8/book 08-4.png","/rc/img/editors/8/book 08-5.png"],userpic:"/rc/img/editors/8/portret-8.png",caption:"издательство «Наука» Академиздатцентра (Новосибирский филиал), медицинское издательство «Таркомм» (Москва), Институт родословия и геральдики (Москва), издательский сервис Rideró."},{id:"inna-haritonova",name:"Инна Харитонова",specialization:"гуманитарная (нон-фикшн), художественная литература.",covers:["/rc/img/editors/9/book 09-1.png","/rc/img/editors/9/book 09-2.png","/rc/img/editors/9/book 09-3.png","/rc/img/editors/9/book 09-4.png","/rc/img/editors/9/book 09-5.png"],userpic:"/rc/img/editors/9/portret-9.png",quote:"Редактор — лицо заинтересованное в публикации, так же как и автор. Автор должен доверять редактору — хорошо образованному специалисту с широким мировоззрением, знатоку языка, имеющему достойный художественный вкус. Хороший текст является результатом совместной работы автора, редактора и корректора.",caption:"издательства «У-Фактория», «Флюид-Урал», сетевое издательство «Рунет.ру», издательства «Зебра Е», «Инфра-М», «Вокруг света», «Захаров», АСТ-Neoclassik, «Русский путь» (Москва), «Книжники» (Иерусалим), «Гонзо», Издательство «91», «Литур», «Кабинетный ученый» (Екатеринбург), издательства Уральского государственного университета, Гуманитарного университета (Екатеринбург), Нижневартовского ГПИ (Нижневартовск)."},{id:"ekaterina-dolgova",name:"Екатерина Долгова",specialization:"научная, научно-популярная, публицистическая литература.",covers:["/rc/img/editors/10/book 10-1.png","/rc/img/editors/10/book 10-2.png","/rc/img/editors/10/book 10-3.png","/rc/img/editors/10/book 10-4.png","/rc/img/editors/10/book 10-5.png"],userpic:"/rc/img/editors/10/portret-10.png",caption:"Средне-Уральское книжное издательство, Независимое издательское предприятие «91», «Средне-Уральское книжное издательство. Новое время». Культурологические и литературные журналы в издательствах «МиКС» (Мы и Культура сегодня), «Черный журнал». Газеты и журналы различной направленности (общественно-политические, корпоративные, производственные, научно-популярные)."},{id:"natalya-shevchenko",name:"Наталия Шевченко",specialization:"гуманитарная (нон-фикшн), художественная литература.",covers:["/rc/img/editors/11/book 11-1.png","/rc/img/editors/11/book 11-2.png","/rc/img/editors/11/book 11-3.png","/rc/img/editors/11/book 11-4.png","/rc/img/editors/11/book 11-5.png"],userpic:"/rc/img/editors/11/portret-11.png",quote:"Никто не рождается готовым писателем, и из вуза никто не выходит готовым редактором, но с каждой новой книгой, сделанной совместными усилиями, оба помогают друг другу расти в своем мастерстве.",caption:"издательский отдел Свердловского государственного педагогического института, издательства «У-Фактория», «УльтраКультура», «Флюид-Урал», издательский отдел Екатеринбургской академии современного искусства, издательство Уральского университета, издательства «Гонзо», «Кабинетный ученый»."},{id:"sergei-barhanov",name:"Сергей Барханов",specialization:"художественная, публицистика, научно-популярная литература.",covers:["/rc/img/editors/12/book 12-1.png","/rc/img/editors/12/book 12-2.png","/rc/img/editors/12/book 12-3.png","/rc/img/editors/12/book 12-4.png","/rc/img/editors/12/book 12-5.png"],userpic:"/rc/img/editors/12/portret-12.png",quote:"Как легко быть автором: взял лист бумаги и ручку или открыл ноутбук — и твори сколько душе угодно. Но в то же время как это трудно! Ведь столько хочется сказать миру, стольким хочется поделиться со своей аудиторией. И невольно думается: «А так ли я пишу? Поймут ли меня мои читатели? Сумел ли я донести до них свои мысли?» Что же делать, если одолевают такие сомнения? А просто не нужно бояться. Пишите! Ведь у вас есть тест-читатель — это мы. Мы честно расскажем вам обо всех достоинствах и недостатках вашей книги, и тогда она точно увидит свет такой, какой вы её задумывали.",caption:"журналист, филолог, редактор, корректор. Работал в различных региональных и федеральных СМИ. Издательства «Биржа плюс», «Доброе слово», «Газетный мир» (Нижний Новгород), издательский дом «Имя» (Нижний Новгород), издательство «Юстицинформ» (Москва), дизайн-студия «Аэроплан» (Санкт-Петербург), издательский сервис Rideró."},{id:"marta-sharlatay",name:"Марта Шарлай",specialization:"художественная, научно-популярная, научная литература.",covers:["/rc/img/editors/13/book 13-1.png","/rc/img/editors/13/book 13-2.png","/rc/img/editors/13/book 13-3.png","/rc/img/editors/13/book 13-4.png","/rc/img/editors/13/book 13-5.png"],userpic:"/rc/img/editors/13/portret-13.png",caption:"корректор, редактор, составитель. Издательства «У-Фактория», АМБ (Екатеринбург), «Кабинетный ученый» и др. В течение 10 лет редактировала журнал «Стандартные образцы», большой опыт редактирования медицинской литературы."},{id:"sergei-kim",name:"Сергей Ким",specialization:"публицистика, научно-популярная и художественная литература.",covers:["/rc/img/editors/14/book 14-1.png","/rc/img/editors/14/book 14-2.png","/rc/img/editors/14/book 14-3.png","/rc/img/editors/14/book 14-4.png","/rc/img/editors/14/book 14-5.png"],userpic:"/rc/img/editors/14/portret-14.png",caption:"издательства Common place, Ad marginem, «Новое издательство», проект «Прожито», издательский сервис Rideró."},{id:"anna-baskaeva",name:"Анна Баскаева",specialization:"фантастика, постапокалипсис, популярная психология, young adult, драматургия.",covers:["/rc/img/editors/15/book 15-1.png","/rc/img/editors/15/book 15-2.png","/rc/img/editors/15/book 15-3.png","/rc/img/editors/15/book 15-4.png","/rc/img/editors/15/book 15-5.png"],userpic:"/rc/img/editors/15/portret-15.png",caption:"издательства «Нигма», «Манн, Иванов и Фербер», «Издательский Дом Мещерякова»."},{id:"marina-jivulina",name:"Марина Живулина",specialization:"деловая (менеджмент, экономика, маркетинг, реклама, HR) и художественная литература.",covers:["/rc/img/editors/16/book 16-1.png","/rc/img/editors/16/book 16-2.png","/rc/img/editors/16/book 16-3.png","/rc/img/editors/16/book 16-4.png","/rc/img/editors/16/book 16-5.png"],userpic:"/rc/img/editors/16/portret-16.png",quote:"Лев Толстой когда-то сказал: «Если вы можете не писать, не пишите». Но, добавим от себя, если ваша история рвется наружу — вы просто должны послушать ее и выпустить в мир. Кто знает, может быть, именно она изменит реальность. И даже если ваша книга побудит всего одного-единственного человека задуматься о том, чтобы стать лучше и чище, интереснее и глубже, вы уже — победили.",caption:"газета «Московский комсомолец – Урал», журналы «Уральский рынок металлов», «The Chief-Урал», «Банзай», «National Business» (ИД «Банзай»), «Топ-бизнес» (ИД «Топ-медиа»), «Екатеринбург», «Мистер Стольник» (ИД «Стольник»), в настоящее время — «Деловая Россия» (Издательство «Медиа-Бизнес»), «Облик», издательский сервис Rideró."},{id:"elena-nekrasova",name:"Елена Некрасова",specialization:"художественная, гуманитарная, публицистика, мемуарная литература, литература для детей и подростков.",covers:["/rc/img/editors/17/book 17-1.png"],userpic:"/rc/img/editors/17/portret-17.png",caption:"филолог, журналист. Почти 20 лет работы в СМИ федеральной корпорации (ТВ, радио), сотрудничество с региональными печатными СМИ в качестве автора."},{id:"alexandr-morsin",name:"Александр Морсин",specialization:"научно-популярная литература, публицистика, интервью.",covers:["/rc/img/editors/19/book 19-1.png","/rc/img/editors/19/book 19-2.png","/rc/img/editors/19/book 19-3.png","/rc/img/editors/19/book 19-4.png"],userpic:"/rc/img/editors/19/portret-19.png",caption:"автор книги «Школа IQ007: Как мы всех научили писать». Публиковался в изданиях «Медуза», «Сноб», «Нож», ТАСС. Музыкальный критик."},{id:"andrei-dmitrevskyi",name:"Андрей Дмитревский",specialization:"публицистика, художественная, историческая литература.",covers:["/rc/img/editors/23/book 23-1.png","/rc/img/editors/23/book 23-2.png","/rc/img/editors/23/book 23-3.png","/rc/img/editors/23/book 23-4.png"],userpic:"/rc/img/editors/23/portret-23.png",quote:"Как известно, чтобы книга получилась достойной и по форме, и по содержанию, нужен взгляд на это произведение со стороны. Редактор, как правило, первый взыскательный и в то же время доброжелательный читатель авторского текста. С помощью коллег, работающих в этой популярной издательской системе, я сам выпустил две книги, а в качестве редактора Rideró подготовил тексты около двадцати изданий, получив благодарственные отзывы ряда авторов.",caption:"редактор отдела спецвыпуска «Известий» газеты «Неделя», главный редактор ряда региональных СМИ столицы. Автор нескольких книг. Член Российского союза писателей, Союзов журналистов РФ и Москвы."},{id:"anna-abramova",name:"Анна Абрамова",specialization:"научная, научно-популярная, учебная, методическая, художественная литература.",covers:["/rc/img/editors/24/book 24-1.png","/rc/img/editors/24/book 24-2.png","/rc/img/editors/24/book 24-3.png"],userpic:"/rc/img/editors/24/portret-24.png",caption:"редакционно-издательский сектор Ресурсного центра Новосибирского государственного университета экономики и управления, издательство «Атлант» (Санкт-Петербург), книжная типография «Первый том» (Москва), издательский сервис Rideró."}];var E=function(e){var t=e.onClick;return d.default.createElement("div",{className:m.default.next,onClick:function(e){e.stopPropagation(),e.nativeEvent.stopImmediatePropagation(),t()}})},k=function(e){var t=e.onClick;return d.default.createElement("div",{className:m.default.prev,onClick:function(e){e.stopPropagation(),e.nativeEvent.stopImmediatePropagation(),t()}})},y=function(e){function t(e){(0,o.default)(this,t);var a=(0,s.default)(this,(t.__proto__||(0,n.default)(t)).call(this,e));return a.open=function(e){a.setState({visible:!0,bubble:{x:e.clientX-.5*window.innerWidth,y:e.clientY-.5*window.innerHeight}})},a.handleSwipeStart=function(){return a.setState({swiping:!0})},a.handleSwipeEnd=function(){return a.setState({swiping:!1})},a.close=function(){return a.setState({visible:!1,visibleHelp:!1})},a.handleHelp=function(){return a.setState({visibleHelp:!0})},a.handleClick=function(e,t){a.setState({iframeSrc:"/services-popup/?editing[type]"+t+"[/type]"},a.open(e))},a.showSlider=function(e){document.body.style.overflowY="hidden",a.setState({showSlider:!0,currentSlide:e})},a.hideSlider=function(e){document.body.style.overflowY="auto",a.setState({showSlider:!1})},a.state={visible:!1,visibleEditors:!1,visibleHelp:!1,type:null,swiping:!1,showSlider:!1,currentSlide:0,isMobile:!1},a.settings={centerMode:!0,dots:!1,slidesToShow:3,speed:500,touchMove:!0,nextArrow:d.default.creat