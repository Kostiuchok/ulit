(function () {
  window.setSpansIntoEl = function (el, discussedParagraphs, className) {
    const innerHtml = removeSpansFromEl(el);

    const paragraphHash = _.get(discussedParagraphs, '0.paragraphHash');

    const spans = splitCrossedDiscussions(discussedParagraphs);

    let out = '';
    let charCounter = 0;
    let openElement = null;
    let openAttrs = [];

    htmlParse(innerHtml, {
      openElement: (name) => {
        if (!openElement) {
          openElement = name;

          return;
        }

        out += openTag(openElement, openAttrs);
        openElement = name;
        openAttrs = [];
      },
      closeElement: (name) => {
        out += closeTag(name);
      },
      attribute: (name, value) => {
        openAttrs.push({
          name,
          value,
        });
      },
      text: (value) => {
        if (openElement) {
          out += openTag(openElement, openAttrs);
          openAttrs = [];
          openElement = null;
        }

        const re = /&nbsp;/g;
        value = value.replace(re, '☘');

        const leftBound = charCounter;
        const rightBound = charCounter + value.length;

        charCounter = rightBound;

        let stack = [];

        for (const span of spans) {
          if (!span.startOffset || !span.endOffset) {
            continue;
          }
          if (span.startOffset >= leftBound && span.startOffset < rightBound) {
            stack.push({
              type: 'open',
              offset: span.startOffset,
              realStartOffset: span.realStartOffset,
              realEndOffset: span.realEndOffset,
              endOffset: span.endOffset
            });
          }

          if (span.endOffset >= leftBound && span.endOffset < rightBound) {
            stack.push({
              type: 'close',
              offset: span.endOffset
            });
          }
        }

        stack = _.sortBy(stack, 'offset');

        let currentIndex = 0;

        while (stack.length) {
          const item = stack.shift();
          out += value.substring(currentIndex, item.offset);
          if (item.type === 'open') {
            out += openTag('text', [
              {
                name: 'class',
                value: className,
              },
              {
                name: 'realStartOffset',
                value: item.realStartOffset,
              },
              {
                name: 'realEndOffset',
                value: item.realEndOffset,
              },
              {
                name: 'startOffset',
                value: item.offset,
              },
              {
                name: 'endOffset',
                value: item.endOffset,
              },
              {
                name: 'paragraphHash',
                value: paragraphHash,
              },
            ]);
          }

          if (item.type === 'close') {
            out += closeTag('text');
          }
          currentIndex = item.offset;
        }

        out += value.substring(currentIndex, rightBound);
      },
    });

    return out.replace(/☘/g, '&nbsp;');
  };

  window.setMarksInElement = function (el, startOffset, endOffset, className) {
    var out = '';
    var charCounter = 0;
    var innerHtml = deleteMarksFromEl(el);
    var openElement = null;
    var openAttrs = [];

    var markAttrs = className ? [{ name: 'class', value: className }] : [];

    htmlParse(innerHtml, {
      openElement: (name) => {
        if (!openElement) {
          openElement = name;

          return;
        }

        out += openTag(openElement, openAttrs);
        openElement = name;
        openAttrs = [];
      },
      closeElement: (name) => {
        out += closeTag(name);
      },
      attribute: (name, value) => {
        openAttrs.push({
          name,
          value,
        });
      },
      text: (value) => {
        if (openElement) {
          out += openTag(openElement, openAttrs);
          openAttrs = [];
          openElement = null;
        }

        var re = /&nbsp;/g;

        value = value.replace(re, '☘');

        var leftBound = charCounter;
        var rightBound = charCounter + value.length;
        charCounter = rightBound;

        if (leftBound >= endOffset) {
          out += value;

          return;
        }

        if (leftBound >= startOffset) {
          out += openTag('mark', markAttrs);
          if (rightBound <= endOffset) {
            out += value;
            out += closeTag('mark');

            return;
          }

          out += value.substring(0, endOffset - leftBound);
          out += closeTag('mark');
          out += value.substring(endOffset - leftBound);

          return;
        }

        if (startOffset > leftBound) {
          if (endOffset < rightBound) {
            out += value.substring(0, startOffset - leftBound);
            out += openTag('mark', markAttrs);
            out += value.substring(startOffset - leftBound, endOffset - leftBound);
            out += closeTag('mark');
            out += value.substring(endOffset - leftBound, rightBound - leftBound);

            return;
          }

          out += value;

          return;
        }

        out += value;
      },
    });

    return out.replace(/☘/g, '&nbsp;');
  };

  window.deleteMarksFromEl = deleteMarksFromEl;
  window.removeSpansFromEl = removeSpansFromEl;

  function removeSpansFromEl(el) {
    var out = '';
    var innerHtml = el.innerHTML;
    var openElement = null;
    var openAttrs = [];

    htmlParse(innerHtml, {
      openElement: (name) => {
        if (!openElement) {
          openElement = name;

          return;
        }

        if (openElement !== 'text') {
          out += openTag(openElement, openAttrs);
        }
        openElement = name;
        openAttrs = [];
      },
      closeElement: (name) => {
        if (name !== 'text') {
          out += closeTag(name);
        }
      },
      attribute: (name, value) => {
        openAttrs.push({
          name,
          value,
        });
      },
      text: (value) => {
        if (openElement) {
          if (openElement !== 'text') {
            out += openTag(openElement, openAttrs);
          }
          openAttrs = [];
          openElement = null;
        }

        var re = /&nbsp;/g;
        value = value.replace(re, '☘');

        out += value;
      },
    });

    return out.replace(/☘/g, '&nbsp;');
  }

  function deleteMarksFromEl(el) {
    var out = '';
    var innerHtml = el.innerHTML;
    var openElement = null;
    var openAttrs = [];

    htmlParse(innerHtml, {
      openElement: (name) => {
        if (!openElement) {
          openElement = name;

          return;
        }

        if (openElement !== 'mark') {
          out += openTag(openElement, openAttrs);
        }
        openElement = name;
        openAttrs = [];
      },
      closeElement: (name) => {
        if (name !== 'mark') {
          out += closeTag(name);
        }
      },
      attribute: (name, value) => {
        openAttrs.push({
          name,
          value,
        });
      },
      text: (value) => {
        if (openElement) {
          if (openElement !== 'mark') {
            out += openTag(openElement, openAttrs);
          }
          openAttrs = [];
          openElement = null;
        }

        out += value;
      },
    });

    return out;
  }

  function ParseContext() {}

  ParseContext.prototype.create = function(raw, callbacks, regex) {
    var index = 0,
      current = null,
      substring = null;

    var context = {
      text: '',
      peek: function(count) {
        count = count || 1;
        return this.raw.substr(this.index + 1, count);
      },
      read: function(count) {
        if (count === 0) {
          return '';
        }
        count = count || 1;
        var next = this.peek(count);
        this.index += count;
        if (this.index > this.length) {
          this.index = this.length;
        }
        return next;
      },
      readUntilNonWhitespace: function() {
        var value = '', next;
        while (!this.isEof()) {
          next = this.read();
          value += next;
          if (!/\s$/.test(value)) {
            break;
          }
        }

        return value;
      },
      isEof: function() {
        return this.index >= this.length;
      },
      readRegex: function(regex) {
        var value = (regex.exec(this.raw.substring(this.index)) || [''])[0];
        this.index += value.length;
        return value;
      },
      peekIgnoreWhitespace: function(count) {
        count = count || 1;
        var value = '', next = '', offset = 0;
        do {
          next = this.raw.charAt(this.index + ++offset);
          if (!next) {
            break;
          }
          if (!/\s/.test(next)) {
            value += next;
          }
        } while (value.length < count);

        return value;
      }
    };

    context.__defineGetter__('current', function() {
      return this.isEof() ? '' : current === null ? (current = this.raw.charAt(this.index)) : current;
    });
    context.__defineGetter__('raw', function() {
      return raw;
    });
    context.__defineGetter__('length', function() {
      return this.raw.length;
    });
    context.__defineGetter__('index', function() {
      return index;
    });
    context.__defineSetter__('index', function(value) {
      index = value;
      current = null;
      substring = null;
    });
    context.__defineGetter__('substring', function() {
      return substring === null ? (substring = this.raw.substring(this.index)) : substring;
    });

    context.callbacks = {};
    var types = [ 'openElement', 'closeElement', 'attribute', 'comment', 'cdata', 'text', 'docType', 'xmlProlog', 'closeOpenedElement' ];
    types.forEach(function(value) {
      context.callbacks[value] = function() {};
    });

    merge(context.callbacks, callbacks || {});

    context.regex = {
      name: /[a-zA-Z_][\w:\-\.]*/,
      attribute: /[a-zA-Z_][\w:\-\.]*/,
      dataElements: {
        cdata: {
          start: '<![CDATA[',
          end: ']]>'
        },
        comment: {
          start: '<!--',
          end: '-->'
        },
        docType: {
          start: /^<!DOCTYPE /i,
          end: '>'
        }
      }
    };

    merge(context.regex, regex || {});

    return context;
  };

  var parseContext = new ParseContext();

  function htmlParse(htmlString, callbacks, regex) {
    htmlString = htmlString.replace(/\\r\\n/g, '\\n').replace(/\\r/g, '\\n');
    var context = parseContext.create(htmlString, callbacks, regex);
    do {
      parseNext(context);
    } while (!context.isEof());

    callbackText(context);
  }

  function readAttribute(context) {
    var name = context.readRegex(context.regex.attribute);
    var value = null, quote = '';
    if (context.current === '=' || context.peekIgnoreWhitespace() === '=') {
      context.readRegex(/\s*=\s*/);
      var attributeValueRegex;
      switch (context.current) {
        case "'":
          attributeValueRegex = /('(\\'|<%.*?%>|[^'])*?')/;
          quote = "'";
          break;
        case '"':
          attributeValueRegex = /("(\\"|<%.*?%>|[^"])*?")/;
          quote = '"';
          break;
        case '<':
          attributeValueRegex = (context.peek() === '%') ?
            /(<%.*?%>)/ :
            /(.*?)(?=[\s><])/;
          break;
        default:
          attributeValueRegex = /(.*?)(?=[\s><])/;
          break;
      }

      var match = attributeValueRegex.exec(context.substring) || [0, ''];
      value = match[1];
      context.read(match[0].length);

      if (value[0] === '"' || value[0] === "'") {
        value = value.substring(1);
      }

      if (value[value.length-1] === '"' || value[value.length-1] === "'") {
        value = value.substring(0, value.length-1);
      }
    }

    context.callbacks.attribute(name, value, quote);
  }

  function readAttributes(context, isXml) {
    function isClosingToken() {
      if (isXml) {
        return context.current === '?' && context.peek() === '>';
      }

      return context.current === '>' || (context.current === '/' && context.peekIgnoreWhitespace() === '>');
    }

    var next = context.current, handled;
    while (!context.isEof() && !isClosingToken()) {
      handled = false;
      if (context.current === '<') {
        for (var callbackName in context.regex.dataElements) {
          if (!context.regex.dataElements.hasOwnProperty(callbackName)) {
            continue;
          }

          var dataElement = context.regex.dataElements[callbackName],
            start = dataElement.start,
            isValid = false;

          switch (typeof start) {
            case 'string':
              isValid = context.substring.slice(0, start.length) === start;
              break;
            case 'object':
              isValid = start.test(context.substring);
              break;
            case 'function':
              isValid = start(context.substring) > -1;
              break;
          }

          if (isValid) {
            callbackText(context);
            context.callbacks[callbackName](parseDataElement(context, dataElement));
            next = context.current;
            handled = true;
            break;
          }
          next = context.current;
        }
      }

      if (!handled) {
        if (context.regex.attribute.test(next)) {
          readAttribute(context);
          next = context.current;
        }
        else {
          next = context.read();
        }
      }
    }
  }

  function readCloserForOpenedElement(context, name) {
    var emptyElements = {
      'area': true, 'base': true, 'basefont': true, 'br': true, 'col': true, 'frame': true,
      'hr': true, 'img': true, 'input': true, 'isindex': true, 'link': true, 'meta': true,
      'param': true, 'embed': true
    };

    var isUnary = name in emptyElements;

    if (context.current === '/') {
      context.readUntilNonWhitespace();
      context.read();
      context.callbacks.closeOpenedElement(name, '/>', isUnary);
    }
    else if (context.current === '?') {
      context.read(2);
      context.callbacks.closeOpenedElement(name, '?>', isUnary);
    }
    else {
      context.read();
      context.callbacks.closeOpenedElement(name, '>', isUnary);
    }
  }

  function parseOpenElement(context) {
    var name = context.readRegex(context.regex.name);
    context.callbacks.openElement(name);
    readAttributes(context, false);
    readCloserForOpenedElement(context, name);

    if (!/^(script|xmp|style)$/i.test(name)) {
      return;
    }

    var regex = new RegExp('^([\\s\\S]*?)(?:$|</(' + name + ')\\s*>)', 'i');
    var match = regex.exec(context.substring);
    context.read(match[0].length);
    if (match[1]) {
      context.callbacks.cdata(match[1]);
    }
    if (match[2]) {
      context.callbacks.closeElement(match[2]);
    }
  }

  function parseEndElement(context) {
    var name = context.readRegex(context.regex.name);
    context.callbacks.closeElement(name);
    context.readRegex(/.*?(?:>|$)/);
  }

  function parseDataElement(context, dataElement) {
    var start = dataElement.start,
      data = dataElement.data,
      end = dataElement.end;

    switch (typeof start) {
      case 'string':
        start = start.length;
        break;
      case 'object':
        start = start.exec(context.substring);
        start = start[start.length - 1].length;
        break;
      case 'function':
        start = start(context.substring);
        break;
    }

    context.read(start);

    switch (typeof data) {
      case 'object':
        data = data.exec(context.substring);
        data = data[data.length - 1];
        break;
      case 'function':
        data = data(context.substring);
        break;
      case 'undefined':
        var index = -1;

        switch (typeof end) {
          case 'string':
            index = context.substring.indexOf(end);
            break;
          case 'object':
            var match = context.substring.match(end);
            if (match) {
              match = match[match.length - 1];
              index = context.substring.indexOf(match);
            }
            break;
        }

        data = index > -1 ? context.substring.slice(0, index) : context.substring;
        break;
    }

    context.read(data.length);

    switch (typeof end) {
      case 'string':
        end = end.length;
        break;
      case 'object':
        end = end.exec(context.substring);
        end = end[end.length - 1].length;
        break;
      case 'function':
        end = end(context.substring);
        break;
    }

    context.read(end);

    return data;
  }

  function parseXmlProlog(context) {
    context.read(4);
    context.callbacks.xmlProlog();
    readAttributes(context, true);
    readCloserForOpenedElement(context, '?xml');
  }

  function appendText(value, context) {
    context.text += value;
  }

  function callbackText(context) {
    if (context.text) {
      context.callbacks.text(context.text);
      context.text = '';
    }
  }

  function parseNext(context) {
    if (context.current === '<') {
      var next = context.substring.charAt(1);
      if (next === '/' && context.regex.name.test(context.substring.charAt(2))) {
        context.read(2);
        callbackText(context);
        parseEndElement(context);
        return;
      } else if (next === '?' && /^<\\?xml/.test(context.substring)) {
        context.read(1);
        callbackText(context);
        parseXmlProlog(context);
        return;
      } else if (context.regex.name.test(next)) {
        context.read(1);
        callbackText(context);
        parseOpenElement(context);
        return;
      }
    }

    for (var callbackName in context.regex.dataElements) {
      if (!context.regex.dataElements.hasOwnProperty(callbackName)) {
        continue;
      }

      var dataElement = context.regex.dataElements[callbackName],
        start = dataElement.start,
        isValid = false;

      switch (typeof start) {
        case 'string':
          isValid = context.substring.slice(0, start.length) === start;
          break;
        case 'object':
          isValid = start.test(context.substring);
          break;
        case 'function':
          isValid = start(context.substring) > -1;
          break;
      }

      if (isValid) {
        callbackText(context);
        context.callbacks[callbackName](parseDataElement(context, dataElement));
        return;
      }
    }

    appendText(context.current, context);
    context.read();
  }

  function merge(target, source) {
    for (var name in source) {
      if (!source.hasOwnProperty(name)) continue;

      var value = source[name];

      if (target[name] && typeof value === 'object' && value instanceof RegExp === false) {
        merge(target[name], value);
      } else {
        target[name] = value;
      }
    }
  }

  function openTag(name, attrs) {
    return `<${name}${attrsStr(attrs)}>`;
  }

  function attrsStr(attrs) {
    if (attrs.length === 0) {
      return '';
    }

    return ` ${attrs.map(attr => `${attr.name}=${attr.value}`).join(' ')}`;
  }

  function closeTag(name) {
    return `</${name}>`;
  }

  class Item {
    constructor(parameters) {
      this.startOffset = parameters.startOffset;
      this.endOffset = parameters.endOffset;
      this.realStartOffset = parameters.realStartOffset;
      this.realEndOffset = parameters.realEndOffset;
    }
  }

  class NodeConstructor {
    constructor() {
      this.items = {};
    }

    addItem({ node, realStartOffset, realEndOffset }) {
      if (!this.items[node]) {
        this.items[node] = {
          realStartOffset,
          realEndOffset,
        };
      } else {
        this.items[node] = {
          realStartOffset: Math.min(realStartOffset, this.items[node].realStartOffset),
          realEndOffset: Math.max(realEndOffset, this.items[node].realEndOffset),
        };
      }
    }

    get() {
      return this.items;
    }
  }

  function splitCrossedDiscussions(discussedParagrahs) {
    const stack = JSON.parse(JSON.stringify(discussedParagrahs)).sort(
      (a, b) => (b.endOffset - b.startOffset) - (a.endOffset - a.startOffset),
    );

    const Nodes = new NodeConstructor();

    let result = [];

    for (const paragraph of discussedParagrahs) {
      Nodes.addItem({
        node: paragraph.endOffset,
        realStartOffset: paragraph.startOffset,
        realEndOffset: paragraph.endOffset,
      });
    }

    while (stack.length) {
      const currentParagraph = stack.shift();
      const newResult = [];

      const intersections = findIntersections(currentParagraph, result);

      if (intersections.length) {
        for (const i of intersections) {
          const par = result[i];

          const intersectionPoint = findIntersectionPoint(currentParagraph, par);

          Nodes.addItem({
            node: intersectionPoint,
            realStartOffset: currentParagraph.startOffset,
            realEndOffset: Math.max(par.endOffset, currentParagraph.endOffset),
          });

          Nodes.addItem({
            node: currentParagraph.endOffset,
            realStartOffset: Nodes.get()[currentParagraph.endOffset].realStartOffset,
            realEndOffset: Math.max(par.endOffset, currentParagraph.endOffset),
          });
        }

        const intersectedNodes = findIntersectedNodes(Nodes.get(), currentParagraph);

        for (let i = 0; i <= intersectedNodes.length; i += 1) {
          const item = new Item({
            startOffset: i === 0 ? currentParagraph.startOffset : intersectedNodes[i - 1],
            endOffset: i === intersectedNodes.length
              ? currentParagraph.endOffset
              : intersectedNodes[i],
            realStartOffset: i < intersectedNodes.length
              ? Nodes.get()[intersectedNodes[i]].realStartOffset
              : Nodes.get()[currentParagraph.endOffset].realStartOffset,
            realEndOffset: i < intersectedNodes.length
              ? Nodes.get()[intersectedNodes[i]].realEndOffset
              : Nodes.get()[currentParagraph.endOffset].realEndOffset,
          });
          newResult.push(item);
        }

        for (let i = 0; i < result.length; i += 1) {
          if (intersections.indexOf(i) === -1) {
            if (!isAlreadyInResult(newResult, result[i])) {
              newResult.push(result[i]);
            }
          } else {
            const { nearestToStart, nearestToEnd } = findNearestNodes(Nodes.get(), result[i]);

            if (!isAlreadyInResult(newResult, {
              startOffset: result[i].startOffset,
              endOffset: nearestToStart,
            })) {
              newResult.push({
                startOffset: result[i].startOffset,
                endOffset: nearestToStart,
                realStartOffset: result[i].realStartOffset,
                realEndOffset: result[i].realEndOffset,
              });
            }

            if (!isAlreadyInResult(newResult, {
              startOffset: nearestToEnd,
              endOffset: result[i].endOffset,
            })) {
              newResult.push({
                startOffset: nearestToEnd,
                endOffset: result[i].endOffset,
                realStartOffset: result[i].realStartOffset,
                realEndOffset: result[i].realEndOffset,
              });
            }
          }
        }
        result = newResult;
      } else if (!isAlreadyInResult(result, currentParagraph)) {
        result.push(new Item({
          startOffset: currentParagraph.startOffset,
          endOffset: currentParagraph.endOffset,
          realStartOffset: currentParagraph.startOffset,
          realEndOffset: currentParagraph.endOffset,
        }));
      }
    }

    return _.orderBy(result, ['startOffset', 'endOffset'], ['asc', 'desc']);
  }

  function findIntersections(currentParagraph, result) {
    const indexes = [];

    let i = 0;
    for (const par of result) {
      if (isIntersected(par, currentParagraph)) {
        indexes.push(i);
      }

      i++;
    }

    return indexes;
  }

  function isIntersected(a, b) {
    const length = Math.min(a.endOffset - a.startOffset, b.endOffset - b.startOffset);
    return Math.min(a.endOffset, b.endOffset) - Math.max(a.startOffset, b.startOffset) > 0
      && Math.min(a.endOffset, b.endOffset) - Math.max(a.startOffset, b.startOffset) !== length;
  }

  function findIntersectionPoint(currentPargraph, paragraph) {
    if (paragraph.startOffset > currentPargraph.startOffset) {
      return paragraph.startOffset;
    }

    return paragraph.endOffset;
  }

  function findIntersectedNodes(Nodes, par) {
    var result = [];

    for (var node of Object.keys(Nodes)) {
      node = Number(node);
      if (node > par.startOffset && node < par.endOffset) {
        result.push(node);
      }
    }

    return result.sort();
  }

  function findNearestNodes(Nodes, par) {
    var nearestToStart = Math.min.apply(
      null,
      Object.keys(Nodes).filter(node => node > par.startOffset),
    );
    var nearestToEnd = Math.max.apply(
      null,
      Object.keys(Nodes).filter(node => node < par.endOffset),
    );

    return {
      nearestToStart,
      nearestToEnd,
    };
  }

  function isAlreadyInResult(result, par) {
    return _.find(result, item => (
      item.startOffset === par.startOffset && item.endOffset === par.endOffset
    ));
  }
}.call(this));
