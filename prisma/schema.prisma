generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CONTENT
  SALES
  CUSTOMER
  WHOLESALE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CategoryStatus {
  ACTIVE
  DISABLED
  HIDDEN
}

enum ViewType {
  GRID
  LIST
  COMPACT
}

enum ProductStatus {
  ACTIVE
  DISABLED
  HIDDEN
}

enum OutOfStockAction {
  DENY
  PREORDER
  NOTIFY
}

enum FeaturePurpose {
  FILTER
  VARIATION
  BRAND
  INFO
}

enum FeatureType {
  TEXT
  NUMBER
  SELECT
  CHECKBOX
  COLOR
}

enum FilterType {
  CHECKBOX
  RANGE
  NONE
}

enum FeatureStatus {
  ACTIVE
  HIDDEN
  DISABLED
}

enum FilterDisplayType {
  EXPANDED
  COLLAPSED
  SLIDER
}

enum OrderStatus {
  NEW
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  LIQPAY
  MONOBANK
  WAYFORPAY
  CASH_ON_DELIVERY
  PRIVAT24_INSTALLMENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShipmentStatus {
  PREPARING
  HANDED_TO_NP
  IN_TRANSIT
  ARRIVED
  DELIVERED
  RETURNING
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PageType {
  PAGE
  FORM
}

enum PageStatus {
  ACTIVE
  DISABLED
}

enum TagStatus {
  ACTIVE
  DISABLED
}

enum BannerStatus {
  ACTIVE
  DISABLED
}

enum PromoZone {
  CART
  CATALOG
}

enum PromoStatus {
  ACTIVE
  HIDDEN
  DISABLED
}

enum GiftCertStatus {
  ACTIVE
  USED
  EXPIRED
}

enum SubStatus {
  ACTIVE
  UNSUBSCRIBED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum StickerColor {
  RED
  GREEN
  BLUE
  ORANGE
  PURPLE
  GRAY
}

enum MenuStatus {
  ACTIVE
  DISABLED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

enum SeoRedirectCode {
  REDIRECT_301
  REDIRECT_302
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           Int        @id @default(autoincrement())
  email        String?    @unique
  phone        String?    @unique
  passwordHash String?
  firstName    String?
  lastName     String?
  middleName   String?
  company      String?
  edrpou       String?
  language     String     @default("uk")
  taxExempt    Boolean    @default(false)
  status       UserStatus @default(ACTIVE)
  role         UserRole   @default(CUSTOMER)
  createdAt    DateTime   @default(now())
  lastLoginAt  DateTime?

  orders    Order[]
  addresses UserAddress[]
  reviews   Review[]
}

model UserAddress {
  id        Int     @id @default(autoincrement())
  userId    Int
  address   String
  city      String
  zip       String?
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Category ────────────────────────────────────────────────────────────────

model Category {
  id              Int            @id @default(autoincrement())
  parentId        Int?
  name            String
  slug            String         @unique
  description     String?
  metaTitle       String?
  metaDescription String?
  customH1        String?
  image           String?
  icon            String?
  status          CategoryStatus @default(ACTIVE)
  position        Int            @default(0)
  defaultView     ViewType       @default(GRID)
  productsPerPage Int            @default(24)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products ProductCategory[]
  features ProductFeature[]  @relation("FeatureCategories")
  filters  ProductFilter[]   @relation("FilterCategories")
  banners  Banner[]          @relation("BannerCategories")

  @@index([parentId])
  @@index([slug])
}

// ─── Product ─────────────────────────────────────────────────────────────────

model Product {
  id               Int              @id @default(autoincrement())
  sku              String           @unique
  name             String
  slug             String           @unique
  price            Decimal          @db.Decimal(10, 2)
  listPrice        Decimal?         @db.Decimal(10, 2)
  qty              Int              @default(0)
  status           ProductStatus    @default(ACTIVE)
  description      String?
  shortDescription String?
  metaTitle        String?
  metaDescription  String?
  customH1         String?
  warrantyMonths   Int?
  returnDays       Int              @default(10)
  trackInventory   Boolean          @default(true)
  outOfStockAction OutOfStockAction @default(DENY)
  noBoxShipping    Boolean          @default(false)
  checkboxName     String?
  uktZed           String?
  weight           Decimal?         @db.Decimal(8, 3)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  categories       ProductCategory[]
  images           ProductImage[]
  videos           ProductVideo[]
  featureValues    ProductFeatureValue[]
  prices           ProductPrice[]
  stickers         ProductSticker[]
  reviews          Review[]
  tags             Tag[]             @relation("ProductTags")
  variationGroupId Int?
  variationGroup   ProductVariationGroup? @relation(fields: [variationGroupId], references: [id])
  creditSettings   ProductCreditSettings?
  requiredBy       Product[]         @relation("RequiredProducts")
  requires         Product[]         @relation("RequiredProducts")
  bundleItems      ProductBundleItem[]
  orderItems       OrderItem[]

  @@index([slug])
  @@index([sku])
  @@index([status])
}

model ProductCategory {
  productId  Int
  categoryId Int
  position   Int     @default(0)
  isPrimary  Boolean @default(false)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVideo {
  id        Int     @id @default(autoincrement())
  productId Int
  type      String
  videoId   String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariationGroup {
  id       Int       @id @default(autoincrement())
  name     String?
  products Product[]
}

model ProductPrice {
  id          Int      @id @default(autoincrement())
  productId   Int
  minQty      Int      @default(1)
  price       Decimal  @db.Decimal(10, 2)
  userGroupId Int?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductCreditSettings {
  id              Int     @id @default(autoincrement())
  productId       Int     @unique
  privat24Enabled Boolean @default(true)
  minMonths       Int     @default(1)
  maxMonths       Int     @default(6)
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSticker {
  id        Int          @id @default(autoincrement())
  productId Int
  label     String
  color     StickerColor @default(RED)
  position  Int          @default(0)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductBundle {
  id          Int                 @id @default(autoincrement())
  name        String
  description String?
  image       String?
  activeFrom  DateTime?
  activeTo    DateTime?
  status      PromoStatus         @default(ACTIVE)
  items       ProductBundleItem[]
}

model ProductBundleItem {
  id        Int           @id @default(autoincrement())
  bundleId  Int
  productId Int
  qty       Int           @default(1)
  discount  Decimal?      @db.Decimal(5, 2)
  bundle    ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])

  @@index([bundleId])
}

// ─── Product Features ─────────────────────────────────────────────────────────

model ProductFeatureGroup {
  id          Int            @id @default(autoincrement())
  name        String
  displayName String
  position    Int            @default(0)
  status      FeatureStatus  @default(ACTIVE)
  features    ProductFeature[]
}

model ProductFeature {
  id              Int            @id @default(autoincrement())
  name            String
  displayName     String
  purpose         FeaturePurpose @default(INFO)
  valueType       FeatureType    @default(TEXT)
  filterType      FilterType     @default(NONE)
  prefix          String?
  suffix          String?
  position        Int            @default(0)
  status          FeatureStatus  @default(ACTIVE)
  showOnProduct   Boolean        @default(true)
  showInList      Boolean        @default(false)
  showInHeader    Boolean        @default(false)
  useForShortDesc Boolean        @default(false)
  groupId         Int?
  createdAt       DateTime       @default(now())

  group      ProductFeatureGroup?   @relation(fields: [groupId], references: [id])
  variants   ProductFeatureVariant[]
  values     ProductFeatureValue[]
  categories Category[]            @relation("FeatureCategories")
  filters    ProductFilter[]

  @@index([groupId])
}

model ProductFeatureVariant {
  id        Int            @id @default(autoincrement())
  featureId Int
  value     String
  position  Int            @default(0)
  feature   ProductFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  values    ProductFeatureValue[]

  @@index([featureId])
}

model ProductFeatureValue {
  id        Int     @id @default(autoincrement())
  productId Int
  featureId Int
  variantId Int?
  value     String?

  product Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  feature ProductFeature         @relation(fields: [featureId], references: [id], onDelete: Cascade)
  variant ProductFeatureVariant? @relation(fields: [variantId], references: [id])

  @@unique([productId, featureId])
  @@index([productId])
  @@index([featureId])
}

// ─── Filters ─────────────────────────────────────────────────────────────────

model ProductFilter {
  id          Int               @id @default(autoincrement())
  name        String
  featureId   Int
  displayType FilterDisplayType @default(EXPANDED)
  maxVisible  Int               @default(10)
  position    Int               @default(0)
  status      FeatureStatus     @default(ACTIVE)

  feature    ProductFeature @relation(fields: [featureId], references: [id])
  categories Category[]     @relation("FilterCategories")

  @@index([featureId])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                Int           @id @default(autoincrement())
  userId            Int?
  status            OrderStatus   @default(NEW)
  paymentMethod     PaymentMethod @default(CASH_ON_DELIVERY)
  paymentStatus     PaymentStatus @default(PENDING)
  subtotal          Decimal       @db.Decimal(10, 2)
  shippingCost      Decimal       @db.Decimal(10, 2) @default(0)
  discount          Decimal       @db.Decimal(10, 2) @default(0)
  total             Decimal       @db.Decimal(10, 2)
  customerNote      String?
  adminNote         String?
  tthNumber         String?
  npCity            String?
  npBranchRef       String?
  npBranchAddress   String?
  customerFirstName String?
  customerLastName  String?
  customerPhone     String?
  customerEmail     String?
  giftCertCode      String?
  giftCertAmount    Decimal?      @db.Decimal(10, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user      User?         @relation(fields: [userId], references: [id])
  items     OrderItem[]
  shipments Shipment[]
  returns   ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int?
  name      String
  sku       String
  qty       Int
  price     Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Shipment {
  id          Int            @id @default(autoincrement())
  orderId     Int
  tthNumber   String?
  status      ShipmentStatus @default(PREPARING)
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([tthNumber])
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id            Int          @id @default(autoincrement())
  productId     Int
  userId        Int?
  authorName    String
  rating        Int
  pros          String?
  cons          String?
  comment       String?
  photos        String[]
  helpful       Int          @default(0)
  notHelpful    Int          @default(0)
  status        ReviewStatus @default(PENDING)
  verifiedBuyer Boolean      @default(false)
  createdAt     DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([status])
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  status   TagStatus @default(ACTIVE)
  products Product[] @relation("ProductTags")
  posts    BlogPost[] @relation("PostTags")
}

// ─── Pages ───────────────────────────────────────────────────────────────────

model Page {
  id              Int        @id @default(autoincrement())
  parentId        Int?
  title           String
  slug            String     @unique
  content         String?
  type            PageType   @default(PAGE)
  metaTitle       String?
  metaDescription String?
  status          PageStatus @default(ACTIVE)
  position        Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  parent   Page?  @relation("PageTree", fields: [parentId], references: [id])
  children Page[] @relation("PageTree")

  @@index([slug])
}

// ─── Menus ───────────────────────────────────────────────────────────────────

model Menu {
  id     Int        @id @default(autoincrement())
  name   String
  slot   String?
  status MenuStatus @default(ACTIVE)
  items  MenuItem[]
}

model MenuItem {
  id         Int     @id @default(autoincrement())
  menuId     Int
  parentId   Int?
  label      String
  url        String?
  pageId     Int?
  categoryId Int?
  icon       String?
  position   Int     @default(0)
  newTab     Boolean @default(false)

  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent   MenuItem?  @relation("MenuTree", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuTree")

  @@index([menuId])
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogPost {
  id              Int            @id @default(autoincrement())
  title           String
  slug            String         @unique
  content         String?
  excerpt         String?
  image           String?
  metaTitle       String?
  metaDescription String?
  status          BlogPostStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tags     Tag[]        @relation("PostTags")
  comments BlogComment[]

  @@index([slug])
  @@index([status])
}

model BlogComment {
  id          Int      @id @default(autoincrement())
  postId      Int
  authorName  String
  authorEmail String?
  content     String
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ─── Banners ─────────────────────────────────────────────────────────────────

model BannerGroup {
  id      Int      @id @default(autoincrement())
  name    String
  slot    String
  banners Banner[]
}

model Banner {
  id          Int          @id @default(autoincrement())
  name        String
  groupId     Int?
  title       String?
  description String?
  image       String?
  objectImage String?
  buttonText  String?
  buttonUrl   String?
  colorScheme String       @default("dark")
  position    Int          @default(0)
  status      BannerStatus @default(ACTIVE)

  group      BannerGroup? @relation(fields: [groupId], references: [id])
  categories Category[]   @relation("BannerCategories")

  @@index([groupId])
}

// ─── Promotions ──────────────────────────────────────────────────────────────

model Promotion {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  shortDesc   String?
  image       String?
  zone        PromoZone   @default(CART)
  priority    Int         @default(0)
  exclusive   Boolean     @default(false)
  activeFrom  DateTime?
  activeTo    DateTime?
  status      PromoStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
}

// ─── Gift Certificates ───────────────────────────────────────────────────────

model GiftCertificate {
  id           Int            @id @default(autoincrement())
  code         String         @unique
  fromName     String
  toName       String
  message      String?
  amount       Decimal        @db.Decimal(10, 2)
  balance      Decimal        @db.Decimal(10, 2)
  status       GiftCertStatus @default(ACTIVE)
  deliveryType String         @default("email")
  email        String?
  expiresAt    DateTime?
  createdAt    DateTime       @default(now())

  @@index([code])
}

// ─── Subscribers ─────────────────────────────────────────────────────────────

model Subscriber {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  firstName String?
  status    SubStatus @default(ACTIVE)
  source    String?
  consentAt DateTime  @default(now())
  createdAt DateTime  @default(now())
}

// ─── Return Requests ─────────────────────────────────────────────────────────

model ReturnRequest {
  id        Int          @id @default(autoincrement())
  orderId   Int
  reason    String
  status    ReturnStatus @default(PENDING)
  createdAt DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

// ─── SEO Redirects ───────────────────────────────────────────────────────────

model SeoRedirect {
  id        Int             @id @default(autoincrement())
  fromUrl   String          @unique
  toUrl     String
  code      SeoRedirectCode @default(REDIRECT_301)
  createdAt DateTime        @default(now())
}
