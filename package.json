{
  "name": "knyha-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@prisma/client": "5.22.0",
    "prettier": "^3.3.3",
    "prisma": "5.22.0",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "ioredis": "^5.4.1"
    },
    "neverBuiltDependencies": [
      "canvas"
    ],
    "publicHoistPattern": [
      "@prisma/client"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
