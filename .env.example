# Database
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Authentication & Security
JWT_SECRET=your_jwt_secret_here_generate_with_openssl_rand_-hex_32
ADMIN_EMAIL=admin@ulit.ua
ADMIN_PASSWORD=your_secure_password_here

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# External Services - SMS
TURBOSMS_TOKEN=your_turbosms_token_here

# External Services - Email
RESEND_API_KEY=your_resend_api_key_here

# External Services - Delivery
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key_here

# MinIO Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_minio_access_key_here
MINIO_SECRET_KEY=your_minio_secret_key_here
MINIO_BUCKET=ulit
MINIO_USE_SSL=false
