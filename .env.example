# ═══════════════════════════════════════════════
# .env.production — Production конфігурація
# Скопіювати: cp .env.example .env.production
# НІКОЛИ не комітити .env.production в git!
# ═══════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────
POSTGRES_USER=knyha
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=knyha
DATABASE_URL="postgresql://knyha:CHANGE_ME_STRONG_PASSWORD@postgres:5432/knyha"

# ── Redis ───────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL="redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379"

# ── MinIO ───────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD_MIN_8_CHARS
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET_NAME=knyha-books

# ── Auth ────────────────────────────────────────
NEXTAUTH_URL="https://ulit.render.ua"
NEXTAUTH_SECRET=CHANGE_ME_RUN_openssl_rand_base64_32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Payments ────────────────────────────────────
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=admin@ulit.render.ua

# ── App ─────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_API_URL="https://ulit.render.ua/api"

# ── Grafana ─────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Worker ──────────────────────────────────────
WORKER_SECRET=CHANGE_ME_WORKER_SECRET
